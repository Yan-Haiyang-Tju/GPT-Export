{
  "manifest_version": 3,
  "name": "ChatExport",
  "version": "0.1.0",
  "description": "A local-first extension for backing up visible ChatGPT conversations, files, and exports.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.amazonaws.com/*",
    "https://*.blob.core.windows.net/*",
    "https://*.oaiusercontent.com/*",
    "https://*.oaistatic.com/*",
    "https://*.openai.com/*"
  ],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/i18n.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatExport",
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "src/vault.html"
}
