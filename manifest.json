{
  "manifest_version": 3,
  "name": "ChatGPT 本地备份",
  "version": "0.1.0",
  "description": "将当前可见的 ChatGPT 会话备份到浏览器本地存储，并支持导出 Markdown 或 JSON。",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.amazonaws.com/*",
    "https://*.blob.core.windows.net/*",
    "https://*.oaiusercontent.com/*",
    "https://*.oaistatic.com/*",
    "https://*.openai.com/*"
  ],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/i18n.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatGPT 本地备份",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/vault.html"
}
